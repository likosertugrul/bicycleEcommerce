# Şablon — kopyala: cp .env.example .env  ve değerleri Supabase'den doldur.
# GERÇEK anahtarları BURAYA yazma; yalnızca .env dosyasına yaz (o gitignore'da).

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# 1) Veritabanı (Prisma) — Supabase > Connect > ORMs > Prisma
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# 2) Supabase API — Project Settings > API Keys / Data API
#    (Project URL sadece kök alan; sonuna /rest/v1/ ekleme.)
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[PUBLISHABLE / anon key]"
SUPABASE_SERVICE_ROLE_KEY="[SECRET / service_role key]"   # gizli, sadece sunucu

# 3) Ödeme — iyzico (Sprint 3)
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"
